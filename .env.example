# Required
SYNC_PASSWORD=your_secure_password_here

# Optional
DATABASE_PATH=./jobs.db
DEBUG=
FETCH_DELAY_MIN=100
FETCH_DELAY_MAX=500
MIN_SCORE=10

# Search provider (SearXNG or Google Custom Search)
SEARXNG_URL=http://localhost:8080
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Company Configuration (JSON array)
ASHBY_COMPANIES='[{"Company":"Vercel","AshbySlug":"vercel","Enabled":true},{"Company":"Linear","AshbySlug":"linear","Enabled":true}]'

# OR use comma-separated format
# ASHBY_COMPANIES_COMMA="Vercel:vercel,Linear:linear,Notion:notion"
