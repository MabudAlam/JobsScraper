{
  "name": "frontend",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "opennextjs-cloudflare build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
