{
  "id": "0d2f69b09c440e7f",
  "fields": {
    "apply_url": "https://jobs.ashbyhq.com/skelar/b40a0d1a-502c-4a65-9309-006e172d9b5a/application",
    "company": "skelar",
    "compensation": "",
