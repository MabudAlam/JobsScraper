{
  "id": "643bd1d2d2a19741",
  "fields": {
    "apply_url": "https://jobs.ashbyhq.com/skelar/3e4c5e34-6d84-4a8f-a1a5-2a3de8e6f0c5/application",
    "company": "skelar",
